# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Postgres 15+)
DATABASE_URL=postgres://esop_user:esop_pass@localhost:5432/esop_db

# Redis (Celery broker + cache)
REDIS_URL=redis://localhost:6379/0

# Encryption key for sensitive fields (Fernet key, base64 encoded)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=change-me-generate-a-real-fernet-key

# Security
CSRF_TRUSTED_ORIGINS=http://localhost:8000
SESSION_COOKIE_AGE=3600
ADMIN_IP_ALLOWLIST=

# Feature flags
MFA_ENABLED=False

# File uploads
MAX_UPLOAD_SIZE_MB=10

# Celery
CELERY_TASK_ALWAYS_EAGER=True

# Azure (future)
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER=esop-documents
# AZURE_KEY_VAULT_URL=

